generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 Int                 @id @default(autoincrement())
  username           String              @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bookings           Booking[]
  creditTransactions CreditTransaction[] @relation("CreditTransactionUser")
  adminCreditActions CreditTransaction[] @relation("CreditTransactionAdmin")

  @@index([role])
  @@index([lastName, firstName])
}

model Room {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  imagePath    String?
  capacity     Int
  pricePerHour Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  options      RoomOption[]
  bookings     Booking[]

  @@index([capacity])
}

model ServiceOption {
  id          Int          @id @default(autoincrement())
  key         String       @unique
  name        String
  roomOptions RoomOption[]
}

model RoomOption {
  id              Int           @id @default(autoincrement())
  roomId          Int
  serviceOptionId Int
  price           Int
  enabled         Boolean       @default(true)
  room            Room          @relation(fields: [roomId], references: [id])
  serviceOption   ServiceOption @relation(fields: [serviceOptionId], references: [id])

  @@unique([roomId, serviceOptionId])
  @@index([roomId])
  @@index([serviceOptionId])
}

model Booking {
  id               Int             @id @default(autoincrement())
  userId           Int
  roomId           Int
  bookingDate      DateTime
  startHour        Int
  endHour          Int
  roomNameSnapshot String
  roomPricePerHour Int
  roomBasePrice    Int
  totalPrice       Int
  createdAt        DateTime        @default(now())
  user             User            @relation(fields: [userId], references: [id])
  room             Room            @relation(fields: [roomId], references: [id])
  selectedOptions  BookingOption[]

  @@index([userId])
  @@index([roomId, bookingDate])
  @@index([createdAt])
}

model BookingOption {
  id        Int     @id @default(autoincrement())
  bookingId Int
  name      String
  price     Int
  booking   Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model CreditTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  adminId   Int
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation("CreditTransactionUser", fields: [userId], references: [id])
  admin     User     @relation("CreditTransactionAdmin", fields: [adminId], references: [id])

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}
